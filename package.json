{
	"name": "libuntar",
	"version": "1.0.1",
	"description": "Extract files from .tar and tar.gz archives in the browser (and node) using native APIs",
	"main": "./dist/libuntar.cjs",
	"module": "./dist/libuntar.js",
	"types": "./dist/libuntar.d.ts",
	"exports": {
		".": {
			"types": "./dist/libuntar.d.ts",
			"import": "./dist/libuntar.js",
			"require": "./dist/libuntar.cjs"
		},
		"./untgz": {
			"types": "./dist/untgz.d.ts",
			"import": "./dist/untgz.js",
			"require": "./dist/untgz.cjs"
		}
	},
	"files": [
		"dist",
		"README.md",
		"CHANGELOG.md",
		"LICENSE"
	],
	"scripts": {
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "oxlint .",
		"lint:fix": "oxlint --fix .",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"build": "vite build && tsc --emitDeclarationOnly --outDir dist && pnpm run copy-to-demo",
		"copy-to-demo": "cp dist/libuntar.js dist/untgz.js demo/",
		"typecheck": "tsc --noEmit",
		"test:all": "pnpm run lint && pnpm run typecheck && pnpm test",
		"prepublishOnly": "pnpm run build",
		"release": "GITHUB_TOKEN=$(gh auth token) release-it"
	},
	"type": "module",
	"keywords": [
		"tar",
		"gzip",
		"archive",
		"extract",
		"untar",
		"decompress",
		"browser",
		"typescript"
	],
	"author": "select",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/select/libuntar.git"
	},
	"bugs": {
		"url": "https://github.com/select/libuntar/issues"
	},
	"homepage": "https://select.github.io/libuntar/",
	"license": "MIT",
	"packageManager": "pnpm@10.19.0",
	"devDependencies": {
		"@types/node": "24.9.2",
		"oxlint": "1.24.0",
		"prettier": "3.6.2",
		"typescript": "5.9.3",
		"vite": "7.1.12",
		"vitest": "4.0.4",
		"@release-it/conventional-changelog": "11.0.1",
		"release-it": "20.2.0"
	}
}
